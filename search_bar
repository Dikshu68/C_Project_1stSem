#include <stdio.h>
#include <string.h>

struct details {
    char citizenshipNo[20];
    char name[50];
    char phone[20];
};

int main() {
    FILE *fp;
    struct details d;
    char search[20];
    int found=0;

    fp = fopen("detail.txt", "r");
    if (fp == NULL) {
        printf("File error\n");
        return 1;
    }

    printf("Enter citizenship number prefix: ");
    scanf("%s", search);

    printf("\n\tSuggestions:\n");
    printf("----------------------------------------\n");
    printf("%-20s %-15s %-15s\n", "CitizenshipNo", "Name", "Phone");
    printf("----------------------------------------\n");

    while (fscanf(fp, "%s %s %s", d.citizenshipNo, d.name, d.phone) != EOF) {

        if (strncmp(d.citizenshipNo, search, strlen(search)) == 0)
         {
            printf("%-20s %-15s %-15s\n",  d.citizenshipNo,  d.name,  d.phone);
            found=1;
            break;
        
        }
    }
    if(!found)
    {
    printf("No details found:");
    }
    printf("----------------------------------------\n");

    fclose(fp);
    return 0;
}
